{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://end.teka.eu.org/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://end.teka.eu.org/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
